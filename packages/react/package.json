{
  "name": "@fuma-translate/react",
  "version": "0.0.2",
  "description": "React runtime for fuma-translate",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/fuma-translate",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
